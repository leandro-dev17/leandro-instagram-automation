# =============================================================
# ALERTA PATRIOTA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# NUNCA commitar o .env.local com valores reais
# =============================================================

# BANCO DE DADOS (Neon PostgreSQL — exclusivo Alerta Patriota)
DATABASE_URL=postgresql://neondb_owner:SENHA@ep-XXXX.us-east-1.aws.neon.tech/alertapatriota?sslmode=require

# AUTENTICAÇÃO
JWT_SECRET=gere-uma-chave-secreta-longa-aqui
COOKIE_NAME=alerta-patriota-session
ADMIN_EMAIL=admin@alertapatriota.com.br
CRON_SECRET=segredo-para-proteger-rotas-de-cron

# MERCADO PAGO (credenciais exclusivas Alerta Patriota)
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_PUBLIC_KEY=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=

# WHATSAPP — Evolution API (instância exclusiva)
EVOLUTION_API_URL=https://evolution-api-production-8be2.up.railway.app
EVOLUTION_API_KEY=
EVOLUTION_INSTANCIA=alertapatriota

# IDs dos grupos WhatsApp (preencher após criar os grupos)
WPP_GROUP_BASICO=120363XXXXXXXXXX@g.us
WPP_GROUP_PATRIOTA=120363XXXXXXXXXX@g.us
WPP_GROUP_VIP=120363XXXXXXXXXX@g.us
WPP_GROUP_ELITE=120363XXXXXXXXXX@g.us

# Links de convite dos grupos (preencher após criar os grupos)
WPP_LINK_BASICO=https://chat.whatsapp.com/XXXXXXXX
WPP_LINK_PATRIOTA=https://chat.whatsapp.com/XXXXXXXX
WPP_LINK_VIP=https://chat.whatsapp.com/XXXXXXXX
WPP_LINK_ELITE=https://chat.whatsapp.com/XXXXXXXX

# IA — Claude (chave compartilhada BioNexus)
ANTHROPIC_API_KEY=

# E-MAIL — Brevo (lista exclusiva Alerta Patriota)
BREVO_API_KEY=
BREVO_SENDER_NAME=Alerta Patriota
BREVO_SENDER_EMAIL=noreply@alertapatriota.com.br

# TELEGRAM — Bot exclusivo para notificações do General Alves
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# APP
NEXT_PUBLIC_APP_URL=https://alertapatriota.vercel.app
