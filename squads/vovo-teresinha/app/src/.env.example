# ──────────────────────────────────────────────────────────────────────────────
# Receitinhas da Vovó Teresinha — Variáveis de Ambiente
# Copie este arquivo como .env.local (desenvolvimento) ou configure no
# Vercel Dashboard → Settings → Environment Variables (produção).
# ──────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:senha@host/banco?sslmode=require

# ── Autenticação de Cron Jobs ──────────────────────────────────────────────────
# 🚨 OBRIGATÓRIO EM PRODUÇÃO — SEM ESTA VARIÁVEL TODOS OS CRONS RETORNAM HTTP 401
#
# O Vercel SÓ injeta o header "x-vercel-cron: 1" nas requisições de cron
# quando CRON_SECRET está definido no projeto. Sem ela, o Vercel não autentica
# os disparos automáticos e todos os endpoints de cron bloqueiam com 401.
#
# Como gerar:
#   openssl rand -hex 32
#
# Como configurar:
#   Vercel Dashboard → [projeto] → Settings → Environment Variables
#   → Adicione: CRON_SECRET = <valor gerado acima>
#   → Escopo: Production (e Preview se necessário)
#   → Clique em Save → Execute um Redeploy manual
#
# Ref: https://vercel.com/docs/cron-jobs/manage-cron-jobs#securing-cron-jobs
CRON_SECRET=GERE_COM_openssl_rand_-hex_32_E_CONFIGURE_NO_VERCEL

# ── App ────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://receitinhas-vovo-teresinha.vercel.app

# ── Push Notifications (VAPID) ─────────────────────────────────────────────────
# Gere com: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ── Telegram (alertas) ────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── MercadoPago ───────────────────────────────────────────────────────────────
MERCADOPAGO_ACCESS_TOKEN=
